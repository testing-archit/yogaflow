{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/crud/:table", "destination": "/api/crud" },
    { "source": "/api/crud/:table/:id", "destination": "/api/crud" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
