generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime
}

model Asana {
  id           String   @id
  englishName  String
  sanskritName String
  description  String?
  benefits     String?
  imageUrl     String?
  difficulty   String   @default("Beginner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  SavedAsana   SavedAsana[]
}

model CommunityConversation {
  id               String             @id
  title            String
  authorId         String
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  User             User               @relation(fields: [authorId], references: [id])
  CommunityMessage CommunityMessage[]
}

model CommunityMessage {
  id                    String                @id
  text                  String
  authorId              String
  conversationId        String
  createdAt             DateTime              @default(now())
  updatedAt             DateTime
  User                  User                  @relation(fields: [authorId], references: [id])
  CommunityConversation CommunityConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ContactRequest {
  id        String   @id
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Instructor {
  id        String      @id
  name      String
  bio       String?
  avatarUrl String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime
  YogaClass YogaClass[]
}

model NewsletterSubscriber {
  id        String   @id
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ResearchTopic {
  id          String    @id
  title       String
  summary     String
  paperLink   String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
}

model Subscription {
  id            String             @id
  userId        String             @unique
  razorpaySubId String?            @unique
  planId        String
  status        SubscriptionStatus @default(INACTIVE)
  trialEndsAt   DateTime?
  validUntil    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime
  User          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model User {
  id                    String                  @id
  clerkId               String?                 @unique
  email                 String                  @unique
  name                  String?
  role                  Role                    @default(USER)
  avatarUrl             String?
  classesAttended       Int                     @default(0)
  hoursPracticed        Float                   @default(0)
  streak                Int                     @default(0)
  lastActiveDate        DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  CommunityConversation CommunityConversation[]
  CommunityMessage      CommunityMessage[]
  Subscription          Subscription?
  Entitlement           Entitlement[]
  UserActivity          UserActivity[]
  SavedAsana            SavedAsana[]
}

model Entitlement {
  id         String   @id
  userId     String
  productKey String
  purchasedAt DateTime @default(now())

  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productKey])
  @@index([productKey])
}

model YogaClass {
  id           String     @id
  title        String
  description  String?
  durationMins Int
  videoUrl     String
  thumbnailUrl String?
  instructorId String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  Instructor   Instructor @relation(fields: [instructorId], references: [id])
  UserActivity UserActivity[]
}

model UserActivity {
  id           String    @id @default(cuid())
  userId       String
  classId      String?
  durationMins Int
  completedAt  DateTime  @default(now())
  
  User         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  YogaClass    YogaClass? @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@index([userId, completedAt])

}

model SavedAsana {
  id        String   @id @default(cuid())
  userId    String
  asanaId   String
  savedAt   DateTime @default(now())

  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Asana     Asana    @relation(fields: [asanaId], references: [id], onDelete: Cascade)

  @@unique([userId, asanaId])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  TRIAL
}
